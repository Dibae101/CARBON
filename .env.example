# ── LLM Configuration ────────────────────────────────────
# Switch provider by changing LLM_PROVIDER:
#   gemini       — Google Gemini (direct API)
#   openai       — OpenAI GPT-4o
#   groq         — Groq Cloud (Llama, Mixtral)
#   gemini-openai — Gemini via OpenAI-compatible endpoint
#   ollama       — Local Ollama

LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=

LLM_API_KEY2=

LLM_API_KEY3=
# ── Examples ─────────────────────────────────────────────
# For Groq:
#   LLM_PROVIDER=groq
#   LLM_API_KEY=
#   LLM_MODEL=llama-3.3-70b-versatile
#
# For OpenAI:
#   LLM_PROVIDER=openai
#   LLM_API_KEY=sk-...
#   LLM_MODEL=gpt-4o

# Legacy keys (for reference)
# GROQ_API_KEY=