# ============================================
# CARBON — .gitignore
# ============================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.pyc
*.pyo
*.pyd

# --- Virtual Environments ---
env/
venv/
ENV/
.venv/
**/env/

# --- Environment Variables & Credentials ---
.env
**/.env
*.env
!.env.example
*credentials*
*apikey*
*api_key*

# --- IDE & Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# --- OS Files ---
.DS_Store
**/.DS_Store
Thumbs.db
desktop.ini

# --- APK Files (large binaries) ---
*.apk

# --- Runtime Artifacts ---
Automation/screenshots/
Automation/chat_history/
Automation/Results/
Automation/logcat.txt
Automation/tmp
Automation/APKs/
*.log
appium.log

# --- Test Output in Dataset ---
Dataset/**/adbgpt_output/
Dataset/**/reactdroid_output/
Dataset/**/carbon_log.txt
Dataset/**/rebl_log.txt
Dataset/**/adbgpt_log.txt
Dataset/**/reactdroid_log.txt
Dataset/**/image.png
Dataset/**/test_logs/

# --- Third-Party Repos (not part of CARBON) ---
test_repo/

# --- Schaumamal (separate project) ---
Schaumamal/

# --- Related Papers (not source code) ---
related_papers/

# --- BugCrawler Output ---
BugCrawler/output/

# --- Extracted/Generated Data ---
rebl_extracted_data.json
extract_rebl_data.py

# --- Temporary Files ---
**/tmp
*.tmp
*.temp
_adbgpt_run.py
_reactdroid_run.py

# --- Python Distribution ---
build/
dist/
*.egg-info/
*.egg

# --- Test & Coverage ---
.pytest_cache/
.coverage
htmlcov/
.tox/

# --- Misc ---
*.orig
*.bak
uiautomatorviewer.sh
overnight_test.log
tested_apk_brs/
